#!/usr/bin/env node
/**
 * A3M Router — Standalone CLI
 * =============================
 * Zero dependencies. Just: chmod +x a3m && ./a3m "your query"
 *
 * Features:
 *   - 14 built-in providers (auto-detects API keys from env)
 *   - Parallel ensemble mode (run N providers simultaneously)
 *   - Automatic fallback (try A -> B -> C on failure)
 *   - Rich ANSI output without chalk
 *   - Single file, no npm install required
 *
 * Usage:
 *   ./a3m "what is the capital of France?"
 *   ./a3m --provider groq "tell me a joke"
 *   ./a3m --ensemble "compare responses across providers"
 *   ./a3m --fallback "try providers until one works"
 *   ./a3m --list-providers
 *   ./a3m --help
 */

// =====================================================================
//  ANSI COLORS (no chalk dependency)
// =====================================================================
const C = {
  reset: '\x1b[0m',
  bold: '\x1b[1m',
  dim: '\x1b[2m',
  italic: '\x1b[3m',
  ul: '\x1b[4m',

  red: '\x1b[31m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  magenta: '\x1b[35m',
  cyan: '\x1b[36m',
  white: '\x1b[37m',

  bgRed: '\x1b[41m',
  bgGreen: '\x1b[42m',
  bgYellow: '\x1b[43m',
  bgBlue: '\x1b[44m',
  bgMagenta: '\x1b[45m',
  bgCyan: '\x1b[46m',

  // Bright variants
  brightRed: '\x1b[91m',
  brightGreen: '\x1b[92m',
  brightYellow: '\x1b[93m',
  brightBlue: '\x1b[94m',
  brightMagenta: '\x1b[95m',
  brightCyan: '\x1b[96m',
};

function c(code, text) {
  return code + text + C.reset;
}

function colorize(providerName, text) {
  const colors = [C.cyan, C.green, C.yellow, C.magenta, C.brightBlue, C.brightCyan, C.brightGreen, C.brightMagenta];
  let hash = 0;
  for (let i = 0; i < providerName.length; i++) hash = ((hash << 5) - hash) + providerName.charCodeAt(i);
  return colors[Math.abs(hash) % colors.length] + text + C.reset;
}

// =====================================================================
//  PROVIDER DEFINITIONS
// =====================================================================
// Each provider has:
//   - id: short name for --provider flag
//   - name: human-readable
//   - envKey: env var that holds the API key
//   - baseUrl: API endpoint
//   - model: default model
//   - format: 'openai' (standard chat completions) | 'anthropic' | 'google'
//   - headers(): returns {Authorization, Content-Type} etc.
//   - parseResponse(json): extracts {content, model, usage}
// =====================================================================

function getEnv(key, fallback) {
  // Also checks .env file in cwd
  const val = process.env[key];
  if (val && val.length > 0 && val !== '...' && val !== 'sk-...' && val !== 'gsk_...' && val !== 'nvapi-...') return val;
  return fallback || '';
}

function makeProvider(id, name, envKey, baseUrl, model, opts) {
  opts = opts || {};
  return {
    id,
    name,
    envKey,
    baseUrl,
    model: opts.model || model,
    format: opts.format || 'openai',
    maxTokens: opts.maxTokens || 2048,
    priority: opts.priority || 50,
    tier: opts.tier || 'unknown',
    costPerK: opts.costPerK || { input: 0, output: 0 },
    getApiKey() {
      return getEnv(this.envKey);
    },
    isAvailable() {
      return !!this.getApiKey();
    },
    buildBody(prompt, systemPrompt) {
      const msgs = [];
      if (systemPrompt) msgs.push({ role: 'system', content: systemPrompt });
      msgs.push({ role: 'user', content: prompt });
      return { model: this.model, messages: msgs, max_tokens: this.maxTokens };
    },
    buildHeaders() {
      return {
        'Authorization': 'Bearer ' + this.getApiKey(),
        'Content-Type': 'application/json',
      };
    },
    parseResponse(json) {
      if (json.error) throw new Error(json.error.message || JSON.stringify(json.error));
      const choice = json.choices && json.choices[0];
      if (!choice) throw new Error('No response choices returned');
      return {
        content: choice.message ? (choice.message.content || '') : '',
        model: json.model || this.model,
        usage: json.usage || {},
      };
    },
  };
}

function makeGoogleProvider(id, name, envKey, baseUrl, model, opts) {
  opts = opts || {};
  const p = makeProvider(id, name, envKey, baseUrl, model, opts);
  p.format = 'google';
  p.buildHeaders = function () {
    return { 'Content-Type': 'application/json' };
  };
  p.buildBody = function (prompt, systemPrompt) {
    const contents = [];
    if (systemPrompt) {
      contents.push({ role: 'user', parts: [{ text: systemPrompt + '\n\n' + prompt }] });
    } else {
      contents.push({ role: 'user', parts: [{ text: prompt }] });
    }
    return {
      contents,
      generationConfig: { maxOutputTokens: this.maxTokens },
    };
  };
  p.parseResponse = function (json) {
    if (json.error) throw new Error(json.error.message || JSON.stringify(json.error));
    const candidate = json.candidates && json.candidates[0];
    if (!candidate) throw new Error('No candidates returned');
    const parts = candidate.content && candidate.content.parts;
    const text = parts ? parts.map(function (p) { return p.text || ''; }).join('') : '';
    return {
      content: text,
      model: json.modelVersion || this.model,
      usage: {},
    };
  };
  return p;
}

function makeAnthropicProvider(id, name, envKey, baseUrl, model, opts) {
  opts = opts || {};
  const p = makeProvider(id, name, envKey, baseUrl, model, opts);
  p.format = 'anthropic';
  p.buildHeaders = function () {
    return {
      'x-api-key': this.getApiKey(),
      'anthropic-version': '2023-06-01',
      'Content-Type': 'application/json',
    };
  };
  p.buildBody = function (prompt, systemPrompt) {
    return {
      model: this.model,
      max_tokens: this.maxTokens,
      system: systemPrompt || '',
      messages: [{ role: 'user', content: prompt }],
    };
  };
  p.parseResponse = function (json) {
    if (json.error) throw new Error(json.error.message || JSON.stringify(json.error));
    return {
      content: json.content && json.content[0] ? json.content[0].text : '',
      model: json.model || this.model,
      usage: json.usage || {},
    };
  };
  return p;
}

function makeNvidiaProvider(id, name, envKey, baseUrl, model, opts) {
  opts = opts || {};
  const p = makeProvider(id, name, envKey, baseUrl, model, opts);
  // NVIDIA uses nvapi- prefix but still Bearer auth
  p.getApiKey = function () {
    const val = getEnv('NVIDIA_API_KEY');
    return val;
  };
  return p;
}

