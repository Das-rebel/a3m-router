// =====================================================================
//  PROVIDER FACTORY
// =====================================================================

function buildProvider(cfg) {
  if (cfg.format === 'google') {
    const url = cfg.baseUrl + cfg.model + ':generateContent?key=' + getEnv(cfg.envKey);
    return makeGoogleProvider(cfg.id, cfg.name, cfg.envKey, url, cfg.model, cfg);
  }
  if (cfg.format === 'anthropic') {
    return makeAnthropicProvider(cfg.id, cfg.name, cfg.envKey, cfg.baseUrl, cfg.model, cfg);
  }
  if (cfg.id === 'nvidia') {
    return makeNvidiaProvider(cfg.id, cfg.name, cfg.envKey, cfg.baseUrl, cfg.model, cfg);
  }
  return makeProvider(cfg.id, cfg.name, cfg.envKey, cfg.baseUrl, cfg.model, cfg);
}

function getAvailableProviders() {
  return PROVIDERS
    .filter(function (p) { return buildProvider(p).isAvailable(); })
    .sort(function (a, b) { return a.priority - b.priority; });
}

// =====================================================================
//  HTTP REQUEST (no dependencies)
// =====================================================================

function httpsRequest(url, method, headers, body, timeout) {
  return new Promise(function (resolve, reject) {
    timeout = timeout || 30000;
    var u = new URL(url);
    var mod = u.protocol === 'https:' ? require('https') : require('http');

    var options = {
      hostname: u.hostname,
      port: u.port || (u.protocol === 'https:' ? 443 : 80),
      path: u.pathname + u.search,
      method: method || 'GET',
      headers: headers || {},
      timeout: timeout,
    };

    var req = mod.request(options, function (res) {
      var data = '';
      res.on('data', function (chunk) { data += chunk; });
      res.on('end', function () {
        try {
          var parsed = JSON.parse(data);
          resolve({ status: res.statusCode, headers: res.headers, data: parsed, raw: data });
        } catch (e) {
          reject(new Error('Invalid JSON response (' + res.statusCode + '): ' + data.substring(0, 200)));
        }
      });
    });

    req.on('error', function (e) { reject(e); });
    req.on('timeout', function () { req.destroy(); reject(new Error('Request timed out after ' + timeout + 'ms')); });

    if (body) {
      req.write(typeof body === 'string' ? body : JSON.stringify(body));
    }
    req.end();
  });
}

// =====================================================================
//  CALL A SINGLE PROVIDER
// =====================================================================

async function callProvider(providerCfg, prompt, systemPrompt) {
  var provider = buildProvider(providerCfg);
  var startTime = Date.now();

  var body = provider.buildBody(prompt, systemPrompt);
  var headers = provider.buildHeaders();

  var resp = await httpsRequest(provider.baseUrl, 'POST', headers, body, 60000);

  if (resp.status >= 400) {
    var errMsg = resp.data && resp.data.error ? (resp.data.error.message || JSON.stringify(resp.data.error)) : ('HTTP ' + resp.status);
    throw new Error(errMsg);
  }

  var parsed = provider.parseResponse(resp.data);
  var latency = Date.now() - startTime;

  var usage = parsed.usage || {};
  var promptTokens = usage.prompt_tokens || 0;
  var completionTokens = usage.completion_tokens || 0;
  var totalTokens = usage.total_tokens || (promptTokens + completionTokens) || estimateTokens(prompt) + estimateTokens(parsed.content);

  var cost = (promptTokens / 1000000 * providerCfg.costPerK.input) +
             (completionTokens / 1000000 * providerCfg.costPerK.output);

  return {
    provider: providerCfg.name,
    model: parsed.model,
    content: parsed.content || '',
    latency: latency,
    totalTokens: totalTokens,
    cost: cost,
    usage: usage,
    success: true,
  };
}

// =====================================================================
//  TOKEN ESTIMATION (rough)
// =====================================================================

function estimateTokens(text) {
  if (!text) return 0;
  // Rough: ~4 chars per token for English
  return Math.ceil(text.length / 4);
}

// =====================================================================
//  FALLBACK MODE (try providers in priority order)
// =====================================================================

async function withFallback(prompt, opts) {
  opts = opts || {};
  var available = getAvailableProviders();
  if (opts.providerFilter) {
    available = available.filter(function (p) { return opts.providerFilter === p.id; });
  }
  if (available.length === 0) {
    return { success: false, error: 'No providers available. Set at least one API key.', errors: [] };
  }

  var errors = [];
  var systemPrompt = opts.systemPrompt || '';

  // If specific provider requested, try just that one first
  if (opts.providerFilter) {
    var target = available[0];
    try {
      var result = await callProvider(target, prompt, systemPrompt);
      return result;
    } catch (e) {
      errors.push({ provider: target.name, error: e.message });
      return { success: false, error: e.message, errors: errors, provider: target.name };
    }
  }

  // Try each provider in priority order
  for (var i = 0; i < available.length; i++) {
    var p = available[i];
    try {
      var result = await callProvider(p, prompt, systemPrompt);
      result.fallbackAttempts = i;
      return result;
    } catch (e) {
      var emsg = e.message.substring(0, 200);
      errors.push({ provider: p.name, error: emsg });
      // Continue to next provider
    }
  }

  return { success: false, error: 'All providers failed', errors: errors };
}

// =====================================================================
//  ENSEMBLE MODE (run N providers in parallel, merge results)
// =====================================================================

async function runEnsemble(prompt, opts) {
  opts = opts || {};
  var available = getAvailableProviders();
  var systemPrompt = opts.systemPrompt || '';

  // Limit to max providers
  var maxProviders = opts.maxProviders || 5;
  var selected = available.slice(0, maxProviders);

  if (selected.length === 0) {
    return { success: false, error: 'No providers available.', results: [] };
  }

  // Fire all requests in parallel
  var results = await Promise.allSettled(
    selected.map(function (p) {
      return callProvider(p, prompt, systemPrompt);
    })
  );

  var successes = [];
  var failures = [];

  for (var i = 0; i < results.length; i++) {
    var r = results[i];
    if (r.status === 'fulfilled') {
      successes.push(r.value);
    } else {
      failures.push({ provider: selected[i].name, error: r.reason.message || String(r.reason) });
    }
  }

  return {
    success: successes.length > 0,
    totalResults: successes.length,
    totalFailures: failures.length,
    results: successes,
    failures: failures,
  };
}

