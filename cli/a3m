    })();
    var tierColor = p.tier === 'free' ? C.green : p.tier === 'cheap' ? C.cyan : p.tier === 'mid' ? C.yellow : C.magenta;
    var modelStr = p.model.length > 35 ? p.model.substring(0, 33) + '..' : p.model;

