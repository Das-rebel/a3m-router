  console.log('  ' + c(C.dim, '│'));
  console.log('  ' + c(C.dim, '│  Response:'));
  console.log('  ' + c(C.dim, '│'));
  var lines = (result.content || '').split('\n');
  for (var li = 0; li < lines.length; li++) {
    console.log('  ' + c(C.dim, '│ ') + lines[li]);
  }
  console.log('  ' + c(C.dim, '│'));
  console.log('  ' + c(C.dim, '└──────────────────────────────────────────────────────'));
  console.log('');
}

function printEnsembleResults(ensembleResult) {
  console.log('');
  console.log('  ' + c(C.dim, '┌─') + c(C.bold, ' A3M Ensemble (') + c(C.cyan, String(ensembleResult.totalResults)) + c(C.bold, ' responses, ') + c(C.yellow, String(ensembleResult.totalFailures)) + c(C.bold, ' failed) ') + c(C.dim, '────'));
  console.log('');

  var results = ensembleResult.results || [];

  for (var ri = 0; ri < results.length; ri++) {
    var r = results[ri];
    var pColor = colorize(r.provider, r.provider);

    console.log('  ' + c(C.dim, '── ') + c(C.bold, '[' + String(ri + 1) + '] ') + pColor + c(C.dim, '  (') + r.model + ', ' + r.latency + 'ms, ' + (r.cost > 0 ? '$' + r.cost.toFixed(6) : 'free') + ')'));
    console.log('');

    var lines2 = (r.content || '').substring(0, 1000).split('\n');
    for (var lj = 0; lj < Math.min(lines2.length, 20); lj++) {
      console.log('    ' + lines2[lj]);
    }
    if (r.content.length > 1000) {
      console.log(c(C.dim, '    ... (' + (r.content.length - 1000) + ' more chars)'));
    }
    console.log('');
  }

  if (ensembleResult.failures && ensembleResult.failures.length > 0) {
    console.log('  ' + c(C.yellow, '  Failed:'));
    for (var fi = 0; fi < ensembleResult.failures.length; fi++) {
      console.log('    ' + c(C.red, '✗ ') + c(C.bold, ensembleResult.failures[fi].provider) + c(C.dim, ': ' + ensembleResult.failures[fi].error.substring(0, 120)));
    }
    console.log('');
  }

  console.log('  ' + c(C.dim, '└──────────────────────────────────────────────────────'));
  console.log('');
}

// =====================================================================
//  MAIN CLI
// =====================================================================

async function main() {
  var args = process.argv.slice(2);

  // Extract flags
  var flags = { provider: null, ensemble: false, fallback: false, listProviders: false, help: false, verbose: false, maxEnsemble: 5 };

  var queryParts = [];

  for (var ai = 0; ai < args.length; ai++) {
    var arg = args[ai];
    if (arg === '--help' || arg === '-h') {
      flags.help = true;
    } else if (arg === '--list-providers') {
      flags.listProviders = true;
    } else if (arg === '--ensemble' || arg === '-e') {
      flags.ensemble = true;
    } else if (arg === '--fallback' || arg === '-f') {
      flags.fallback = true;
    } else if (arg === '--verbose' || arg === '-v') {
      flags.verbose = true;
    } else if (arg === '--provider' || arg === '-p') {
      flags.provider = args[++ai];
    } else if (arg === '--max-ensemble' || arg === '-m') {
      flags.maxEnsemble = parseInt(args[++ai], 10) || 5;
    } else if (arg.startsWith('--')) {
      // unknown flag, skip
    } else {
      queryParts.push(arg);
    }
  }

  if (flags.help) {
    printHelp();
    return;
  }

  if (flags.listProviders) {
    printProviders();
    return;
  }

  var query = queryParts.join(' ');

  // If no query, show interactive mode
  if (!query) {
    // Check if we should read from stdin
    var stdin = '';
    if (!process.stdin.isTTY) {
      // Read from pipe
      var chunks = [];
      for await (var chunk of process.stdin) chunks.push(chunk);
      stdin = Buffer.concat(chunks).toString('utf-8').trim();
    }

    if (stdin) {
      query = stdin;
    } else {
      printHelp();
      return;
    }
  }

  // Print banner
  printBanner();

  // Check if any providers available
  var available = getAvailableProviders();
  if (available.length === 0) {
    console.log(c(C.red, '  ERROR: No providers available.'));
    console.log('  Set at least one API key as an environment variable:');
    console.log('    export GROQ_API_KEY=gsk_...');
    console.log('    export NVIDIA_API_KEY=nvapi-...');
    console.log('    export GOOGLE_API_KEY=...');
    console.log('');
    console.log('  Or run with --list-providers to see all options.\n');
    process.exit(1);
  }

  console.log(c(C.dim, '  Query: ') + c(C.italic, '"' + query.substring(0, 80) + (query.length > 80 ? '...' : '') + '"'));
  console.log(c(C.dim, '  Providers available: ') + c(C.green, String(available.length)));
  console.log('');

  // Route based on mode
  if (flags.ensemble) {
    var ensembleResult = await runEnsemble(query, { maxProviders: flags.maxEnsemble });
    printEnsembleResults(ensembleResult);
  } else if (flags.fallback || flags.provider) {
    var result = await withFallback(query, { providerFilter: flags.provider });
    if (result.success) {
      printResult(result, flags.verbose);
    } else {
      printResult(result, flags.verbose);
    }
  } else {
    // Default: use highest priority available provider
    var defaultResult = await withFallback(query, { providerFilter: available[0].id });
    if (defaultResult.success) {
      printResult(defaultResult, flags.verbose);
      // Show tip about ensemble
      console.log(c(C.dim, '  💡 Tip: Try ') + c(C.cyan, '--ensemble') + c(C.dim, ' to compare responses from all providers.'));
      console.log(c(C.dim, '  💡 Tip: Try ') + c(C.green, '--provider mistral') + c(C.dim, ' to use a specific provider.'));
      console.log('');
    } else {
      // Fallback: try without filter (full fallback chain)
      console.log(c(C.yellow, '  Primary provider failed. Trying full fallback chain...\n'));
      var fallbackResult = await withFallback(query);
      printResult(fallbackResult, flags.verbose);
    }
  }
}

main().catch(function (err) {
  console.error(c(C.red, '\n  UNEXPECTED ERROR: ') + err.message + '\n');
  process.exit(1);
});
