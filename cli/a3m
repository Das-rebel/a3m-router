  var allProviders = PROVIDERS;
  var available = getAvailableProviders();
  var availableIds = {};
  for (var i = 0; i < available.length; i++) availableIds[available[i].id] = true;

  for (var pi = 0; pi < allProviders.length; pi++) {
    var p = allProviders[pi];
    var avail = availableIds[p.id];
    var statusStr = avail ? c(C.green, '  ✅') : c(C.dim + C.white, '  ❌');
    var keyStr = avail ? c(C.green, '  ✅ KEY SET') : (function () {
